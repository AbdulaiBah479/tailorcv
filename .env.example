# Google Gemini API key (aistudio.google.com) — free tier, no credit card required
GEMINI_API_KEY=

# Upstash Redis (upstash.com) — free tier, no credit card required. Used to store
# paid credit balances. Create a database, then copy these from its REST API section.
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# Your Gumroad seller ID, used to verify incoming webhooks actually came from
# your Gumroad account. Find it in your Gumroad account settings.
GUMROAD_SELLER_ID=

# Maps each Gumroad product permalink to the number of credits it grants.
# The permalink is the last part of your product URL, e.g.
# https://yourname.gumroad.com/l/abc123 -> permalink is "abc123"
GUMROAD_PRODUCT_MAP={"abc123":3,"xyz789":10}
